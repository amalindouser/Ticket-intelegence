# --- Database ---
DATABASE_URL=postgresql://fti_user:your-db-password@localhost:5432/freshdesk_ticket_intelegence

# --- Freshdesk API ---
FRESHDESK_DOMAIN=ainoindonesia.freshdesk.com
FRESHDESK_API_KEY=your-freshdesk-api-key-here

# --- JWT Secret (wajib!) ---
# Generate: openssl rand -hex 32
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# --- AI Provider ---
# Opsional: gunakan "ollama" (default) atau "openai" (Groq/OpenAI)
# AI_PROVIDER=openai
# AI_API_KEY=your-groq-or-openai-api-key
# AI_API_URL=https://api.groq.com/openai/v1/chat/completions
# AI_MODEL=llama3-8b-8192

# --- Server ---
PORT=3000

# --- CORS Origin (domain frontend) ---
# CORS_ORIGIN=https://amalindo.my.id
