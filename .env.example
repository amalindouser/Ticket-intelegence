# --- Database (wajib) ---
# Untuk development lokal:
# DATABASE_URL=postgresql://fti_user@localhost:5433/freshdesk_ticket_intelegence
# Untuk production di server:
DATABASE_URL=postgresql://fti_user:fti_password@<IP_SERVER_ATAU_NAMA_HOST>:5432/freshdesk_ticket_intelegence

# --- Freshdesk API ---
FRESHDESK_DOMAIN=ainoindonesia.freshdesk.com
FRESHDESK_API_KEY=your-freshdesk-api-key-here

# --- JWT Secret (wajib!) ---
# Generate: openssl rand -hex 32
JWT_SECRET=your-random-jwt-secret-at-least-32-chars

# --- Server ---
PORT=3001

# --- Docker Nginx port (optional, default 80) ---
NGINX_PORT=80
