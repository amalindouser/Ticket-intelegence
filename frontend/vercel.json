{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://gpl-generator-paintings-resolve.trycloudflare.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://gpl-generator-paintings-resolve.trycloudflare.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
