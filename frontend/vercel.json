{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://delegation-louisiana-leg-postcards.trycloudflare.com/api/$1"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "https://delegation-louisiana-leg-postcards.trycloudflare.com/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
